# токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ID админов через запятую, свой ID даст @userinfobot
ADMIN_IDS=123456789,987654321

# токен Crypto Pay от @CryptoBot; пусто = крипта отключена
CRYPTOBOT_TOKEN=

DB_PATH=data/shop.db

# публичный адрес страницы подписки, без слэша на конце
PUBLIC_BASE_URL=https://sub.example.com

CONFIG_PATH=config.yml

# для Caddy (профиль proxy: docker compose --profile proxy up -d),
# должен совпадать с доменом из PUBLIC_BASE_URL
DOMAIN=sub.example.com
